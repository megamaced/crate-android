<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Crate's launcher mark: a stylised vinyl disc sitting alongside the
         NC Collectives star in the megamaced suite. Cream disc body on
         Nextcloud-blue background with a punched-through "C" label so
         "Crate" reads at home-screen sizes. Whole composition lives
         inside the 66dp circular safe-zone of the adaptive-icon viewport
         centred on (54, 54). -->

    <!-- Outer disc body — cream, r=32, sits inside the 66dp safe-zone. -->
    <path
        android:fillColor="@color/ic_launcher_foreground"
        android:pathData="M22,54a32,32 0 1,0 64,0a32,32 0 1,0 -64,0z" />

    <!-- Three concentric groove rings drawn as thin strokes for that
         vinyl LP feel without darkening the overall mark. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="@color/ic_launcher_groove"
        android:strokeWidth="0.7"
        android:pathData="M26,54a28,28 0 1,0 56,0a28,28 0 1,0 -56,0z" />
    <path
        android:fillColor="#00000000"
        android:strokeColor="@color/ic_launcher_groove"
        android:strokeWidth="0.7"
        android:pathData="M30,54a24,24 0 1,0 48,0a24,24 0 1,0 -48,0z" />
    <path
        android:fillColor="#00000000"
        android:strokeColor="@color/ic_launcher_groove"
        android:strokeWidth="0.7"
        android:pathData="M34,54a20,20 0 1,0 40,0a20,20 0 1,0 -40,0z" />

    <!-- Centre label, painted in the background blue so it punches
         through the cream disc and the C reads on a blue field. -->
    <path
        android:fillColor="@color/ic_launcher_background"
        android:pathData="M40,54a14,14 0 1,0 28,0a14,14 0 1,0 -28,0z" />

    <!-- "C" letterform: 270° arc opening to the right, centred at the
         label centre, arc radius 7, stroke 3 with rounded caps. Cream
         stroke so it sits proud on the blue label. -->
    <path
        android:strokeColor="@color/ic_launcher_foreground"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M58.95,49.05 A7,7 0 1 0 58.95,58.95" />
</vector>
