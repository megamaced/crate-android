<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Path must match TokenStore.PREFS_FILE ("crate_auth") + ".xml". -->
    <cloud-backup>
        <exclude domain="sharedpref" path="crate_auth.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="crate_auth.xml" />
    </device-transfer>
</data-extraction-rules>
